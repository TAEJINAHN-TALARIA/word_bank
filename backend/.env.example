ANTHROPIC_API_KEY=your_api_key_here
PORT=3000

# Firebase Admin SDK (JSON 한 줄로 압축)
# Firebase Console → 프로젝트 설정 → 서비스 계정 → 새 비공개 키 생성
# 생성된 JSON 파일을 한 줄로 변환: python3 -c "import json,sys; print(json.dumps(json.load(sys.stdin)))" < key.json
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key":"..."}

# 무료 플랜 월 조회 횟수 한도 (기본값: 50)
FREE_MONTHLY_LIMIT=50

# ─── IAP 영수증 검증 ───
# Apple: App Store Connect → 앱 → 인앱 구매 → 공유 비밀 키
APPLE_IAP_SHARED_SECRET=your_apple_shared_secret_here

# Android: Google Play Console → 설정 → API 액세스 → 서비스 계정 JSON
# python3 -c "import json,sys; print(json.dumps(json.load(sys.stdin)))" < service-account.json
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON={"type":"service_account","client_email":"...","private_key":"..."}

# Android 앱 패키지명 (예: com.example.word_bank)
GOOGLE_PLAY_PACKAGE_NAME=com.example.word_bank
